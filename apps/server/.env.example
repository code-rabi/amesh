# Browser admin login. If omitted, the server generates a random UUID password
# at startup and writes it to the server log for that process.
AUTH_ADMIN_PASSWORD=change-me

# Persistent cookie signing secret. Set this if you want browser sessions to
# survive restarts.
AUTH_SESSION_SECRET=replace-with-a-long-random-secret

# Optional node bootstrap gate. Leave unset in local dev if you want open node
# registration.
AMESH_REGISTRATION_TOKEN=

# Optional server bind overrides.
HOST=0.0.0.0
PORT=3001
